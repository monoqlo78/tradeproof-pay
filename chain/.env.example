# TradeProof Pay chain — environment template.
# Copy to `.env` and fill in. NEVER commit the real .env or any private key.

# Deployer wallet private key (0x-prefixed). Fund it with test HSK from the faucet:
#   https://faucet.hsk.xyz
PRIVATE_KEY=

# Optional RPC overrides (defaults baked into hardhat.config.js).
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz
HASHKEY_MAINNET_RPC=https://mainnet.hsk.xyz

# Optional: reuse an already-deployed settlement token instead of deploying a
# fresh MockUSDC. Leave blank to have the deploy script deploy its own MockUSDC.
TOKEN_ADDRESS=
