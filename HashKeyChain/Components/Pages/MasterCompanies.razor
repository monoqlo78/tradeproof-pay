@page "/master/companies"
@rendermode InteractiveServer
@using HashKeyChain.Domain
@using HashKeyChain.Services.Master
@using HashKeyChain.Services.Security
@inject IMasterDataService Master
@inject ICurrentUserContext CurrentUser
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Master_Companies"] — TradeProof Pay</PageTitle>

@if (!CurrentUser.Can(TradeOperation.ManageDemoData))
{
    <div class="alert alert-warning">@L["Master_NoAccess"]</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">@L["Master_Companies"]</h1>
        <div class="btn-group">
            <a class="btn btn-outline-secondary" href="/master/users">@L["Master_Users"]</a>
            <button class="btn btn-primary" @onclick="StartCreate">@L["Master_Company_New"]</button>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (_info is not null)
    {
        <div class="alert alert-success">@_info</div>
    }

    @if (_editing is not null)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">@(_editing.Id == 0 ? L["Master_Company_New"] : L["Master_Edit"])</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">@L["Master_Name"]</label>
                        <input class="form-control" @bind="_editing.Name" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">@L["Master_Wallet"]</label>
                        <input class="form-control font-monospace" @bind="_editing.WalletAddress" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">@L["Master_Country"]</label>
                        <input class="form-control" @bind="_editing.CountryCode" maxlength="8" />
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@L["Master_Save"]</button>
                    <button class="btn btn-outline-secondary" @onclick="() => _editing = null" disabled="@_busy">@L["Master_Cancel"]</button>
                </div>
            </div>
        </div>
    }

    @if (_companies is null)
    {
        <p>@L["Common_Loading"]</p>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@L["Master_Name"]</th>
                    <th>@L["Master_Wallet"]</th>
                    <th>@L["Master_Country"]</th>
                    <th>@L["Master_Users"]</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _companies)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td class="font-monospace small">@c.WalletAddress</td>
                        <td>@c.CountryCode</td>
                        <td>@c.Users.Count</td>
                        <td class="text-end">
                            @if (_confirmDeleteId == c.Id)
                            {
                                <span class="me-2 small">@L["Master_ConfirmDelete"]</span>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(c.Id)" disabled="@_busy">@L["Master_Delete"]</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmDeleteId = null">@L["Master_Cancel"]</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(c)">@L["Master_Edit"]</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmDeleteId = c.Id">@L["Master_Delete"]</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private IReadOnlyList<Company>? _companies;
    private Company? _editing;
    private int? _confirmDeleteId;
    private string? _error;
    private string? _info;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => _companies = await Master.GetCompaniesAsync();

    private void StartCreate()
    {
        _editing = new Company();
        _info = _error = null;
    }

    private void StartEdit(Company c)
    {
        _editing = new Company { Id = c.Id, Name = c.Name, WalletAddress = c.WalletAddress, CountryCode = c.CountryCode };
        _info = _error = null;
    }

    private async Task SaveAsync()
    {
        if (_editing is null) return;
        _busy = true; _error = _info = null;
        try
        {
            if (_editing.Id == 0)
            {
                await Master.CreateCompanyAsync(_editing);
                _info = L["Master_Created"];
            }
            else
            {
                await Master.UpdateCompanyAsync(_editing.Id, _editing);
                _info = L["Master_Updated"];
            }
            _editing = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(int id)
    {
        _busy = true; _error = _info = null;
        try
        {
            await Master.DeleteCompanyAsync(id);
            _info = L["Master_Deleted"];
            _confirmDeleteId = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
